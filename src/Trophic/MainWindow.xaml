<Window x:Class="Trophic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Trophic.Behaviors"
        xmlns:conv="clr-namespace:Trophic.Converters"
        xmlns:controls="clr-namespace:Trophic.Controls"
        xmlns:vm="clr-namespace:Trophic.ViewModels"
        xmlns:helpers="clr-namespace:Trophic.Helpers"
        xmlns:props="clr-namespace:Trophic.Properties"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="550" Width="1000"
        MinHeight="400" MinWidth="520"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FlowDirection="{Binding AppFlowDirection}"
        Icon="pack://application:,,,/Resources/app.ico"
        AutomationProperties.Name="{x:Static props:Strings.AppTitle}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <helpers:BindingProxy x:Key="ViewModelProxy" Data="{Binding}"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFolderCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseFileCommand}"/>
    </Window.InputBindings>

    <Grid>
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource MenuBarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="10,8"
                AutomationProperties.Name="Toolbar">
            <DockPanel>
                <!-- View Options (right-aligned) -->
                <CheckBox DockPanel.Dock="Right"
                          Content="{x:Static props:Strings.ShowHidden}"
                          IsChecked="{Binding ShowHiddenTrophies}"
                          IsEnabled="{Binding IsFileOpen}"
                          VerticalAlignment="Center"
                          Margin="0,0,4,0"
                          FontSize="11"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          AutomationProperties.Name="Show hidden trophies"
                          ToolTip="{x:Static props:Strings.TooltipShowHidden}"/>

                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Open Button (prominent, 3:4 ratio) -->
                <Button Command="{Binding OpenFolderCommand}"
                        Style="{StaticResource ToolbarOpenButton}"
                        AutomationProperties.Name="Open Trophy Folder (Ctrl+O)"
                        ToolTip="{x:Static props:Strings.TooltipOpen}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Static props:Strings.Open}" FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Save Button (only enabled when there are unsaved changes) -->
                <Button x:Name="SaveButton" Command="{Binding SaveCommand}"
                        Style="{StaticResource ToolbarButton}"
                        IsEnabled="{Binding IsSaveButtonEnabled}"
                        AutomationProperties.Name="Save Trophies (Ctrl+S)"
                        ToolTip="{x:Static props:Strings.TooltipSave}" Margin="6,0,0,0">
                    <Grid>
                        <StackPanel x:Name="SavePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Static props:Strings.Save}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel x:Name="SavedPanel" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Collapsed" Opacity="0">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       HorizontalAlignment="Center" Foreground="White"/>
                            <TextBlock Text="{x:Static props:Strings.Saved}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"
                                       Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <!-- Close Button -->
                <Button Command="{Binding CloseFileCommand}"
                        Style="{StaticResource ToolbarButton}"
                        IsEnabled="{Binding IsFileOpen}"
                        AutomationProperties.Name="Close Trophy Folder (Ctrl+W)"
                        ToolTip="{x:Static props:Strings.TooltipClose}" Margin="6,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Static props:Strings.Close}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="10,4"/>

                <!-- Import Button with chevron -->
                <StackPanel Orientation="Horizontal" Margin="6,0,0,0">
                    <Button Style="{StaticResource ToolbarButton}"
                            IsEnabled="{Binding IsFileOpen}"
                            AutomationProperties.Name="{x:Static props:Strings.AutoImportFromWebsite}"
                            ToolTip="{x:Static props:Strings.TooltipImport}"
                            Click="ImportTimestamps_Click">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Static props:Strings.Import}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonChevronOverlay}"
                            Width="14" Height="36" VerticalAlignment="Center"
                            IsEnabled="{Binding IsFileOpen}"
                            AutomationProperties.Name="{x:Static props:Strings.TooltipMoreImport}"
                            ToolTip="{x:Static props:Strings.TooltipMoreImport}"
                            Click="ImportDropdown_Click">
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{x:Static props:Strings.FromWebsite}" Click="ImportTimestamps_Click"
                                         AutomationProperties.Name="{x:Static props:Strings.AutoImportFromWebsite}"/>
                                <MenuItem Header="{x:Static props:Strings.FromTextFile}" Click="ImportFromFile_Click"
                                         ToolTip="{x:Static props:Strings.FromTextFileTooltip}"
                                         AutomationProperties.Name="{x:Static props:Strings.AutoImportFromFile}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <!-- Instant Unlock Button with chevron -->
                <StackPanel Orientation="Horizontal" Margin="6,0,0,0">
                    <Button Command="{Binding InstantUnlockCommand}"
                            Style="{StaticResource ToolbarButton}"
                            Width="62"
                            IsEnabled="{Binding IsFileOpen}"
                            AutomationProperties.Name="{x:Static props:Strings.TooltipUnlockAll}"
                            ToolTip="{x:Static props:Strings.TooltipUnlockAll}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE785;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Static props:Strings.UnlockAll}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonChevronOverlay}"
                            Width="14" Height="36" VerticalAlignment="Center"
                            IsEnabled="{Binding IsFileOpen}"
                            AutomationProperties.Name="{x:Static props:Strings.TooltipMoreUnlock}"
                            ToolTip="{x:Static props:Strings.TooltipMoreUnlock}"
                            Click="UnlockDropdown_Click">
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{x:Static props:Strings.AtTimestamp}" Click="UnlockAtTimestamp_Click"
                                         AutomationProperties.Name="{x:Static props:Strings.AutoUnlockAtTimestamp}"/>
                                <MenuItem Header="{x:Static props:Strings.Randomized}" Click="UnlockRandomized_Click"
                                         AutomationProperties.Name="{x:Static props:Strings.AutoUnlockRandomized}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <!-- Clear All Button with chevron -->
                <StackPanel Orientation="Horizontal" Margin="6,0,0,0">
                    <Button Command="{Binding ClearTrophiesCommand}"
                            Style="{StaticResource ToolbarButton}"
                            IsEnabled="{Binding IsFileOpen}"
                            AutomationProperties.Name="Clear all non-synced trophies"
                            ToolTip="Clear all non-synced trophies">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Static props:Strings.ClearAll}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonChevronOverlay}"
                            Width="14" Height="36" VerticalAlignment="Center"
                            IsEnabled="{Binding IsFileOpen}"
                            AutomationProperties.Name="{x:Static props:Strings.TooltipMoreClear}"
                            ToolTip="{x:Static props:Strings.TooltipMoreClear}"
                            Click="ClearDropdown_Click">
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{x:Static props:Strings.ClearAllIncludingSynced}" Click="ClearAllIncludingSynced_Click"
                                         AutomationProperties.Name="{x:Static props:Strings.AutoClearIncludingSynced}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="10,4"/>

                <!-- Exit Button -->
                <Button Command="{Binding ExitCommand}"
                        Style="{StaticResource ToolbarButton}"
                        AutomationProperties.Name="Exit Software (Alt+F4)"
                        ToolTip="{x:Static props:Strings.TooltipExit}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Static props:Strings.Exit}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="10,4"/>

                <!-- Donate Button -->
                <Button Command="{Binding DonateCommand}"
                        Style="{StaticResource ToolbarButton}"
                        AutomationProperties.Name="Donate to support the project"
                        ToolTip="{x:Static props:Strings.TooltipDonate}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xEB51;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                   HorizontalAlignment="Center" Foreground="{StaticResource DestructiveBrush}"/>
                        <TextBlock Text="{x:Static props:Strings.Donate}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource MenuBarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="10,4"
                AutomationProperties.Name="Status bar">
            <DockPanel>
                <Button x:Name="LanguageButton" DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        Padding="6,1"
                        ToolTip="{x:Static props:Strings.TooltipLanguage}"
                        AutomationProperties.Name="{x:Static props:Strings.TooltipLanguage}"
                        Click="LanguageButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE12B;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding CurrentLanguageName}" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- File path -->
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding LoadedFolderPath}"
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           MaxWidth="200" TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding LoadedFolderPath}"
                           Visibility="{Binding IsFileOpen, Converter={StaticResource BoolToVisibility}}"
                           AutomationProperties.Name="Loaded folder path"/>

                <Rectangle DockPanel.Dock="Left" Width="1" Fill="{StaticResource BorderBrush}" Margin="8,2"
                           Visibility="{Binding IsFileOpen, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Per-type trophy counts -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsFileOpen, Converter={StaticResource BoolToVisibility}}">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource DotPlatinumBrush}" Margin="0,0,3,0"
                             AutomationProperties.Name="{x:Static props:Strings.AutoPlatinum}"/>
                    <TextBlock Text="{Binding PlatinumCount}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="{x:Static props:Strings.AutoPlatinumCount}"/>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource DotGoldBrush}" Margin="8,0,3,0"
                             AutomationProperties.Name="{x:Static props:Strings.AutoGold}"/>
                    <TextBlock Text="{Binding GoldCount}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="{x:Static props:Strings.AutoGoldCount}"/>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource DotSilverBrush}" Margin="8,0,3,0"
                             AutomationProperties.Name="{x:Static props:Strings.AutoSilver}"/>
                    <TextBlock Text="{Binding SilverCount}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="{x:Static props:Strings.AutoSilverCount}"/>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource DotBronzeBrush}" Margin="8,0,3,0"
                             AutomationProperties.Name="{x:Static props:Strings.AutoBronze}"/>
                    <TextBlock Text="{Binding BronzeCount}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="{x:Static props:Strings.AutoBronzeCount}"/>
                </StackPanel>

                <Rectangle DockPanel.Dock="Left" Width="1" Fill="{StaticResource BorderBrush}" Margin="8,2"
                           Visibility="{Binding IsFileOpen, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Earned / Total -->
                <TextBlock DockPanel.Dock="Left" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Text="{Binding EarnedStatusText}"
                           Visibility="{Binding IsFileOpen, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Selection count -->
                <Rectangle DockPanel.Dock="Left" Width="1" Fill="{StaticResource BorderBrush}" Margin="8,2"
                           Visibility="{Binding HasMultipleSelected, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock DockPanel.Dock="Left" Text="{Binding SelectionStatusText}" FontSize="11"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" FontWeight="SemiBold"
                           Visibility="{Binding HasMultipleSelected, Converter={StaticResource BoolToVisibility}}"/>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Info Bar — File metadata & settings -->
            <Border Grid.Row="0" Background="{StaticResource MenuBarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="16,6,16,6"
                    Visibility="{Binding IsFileOpen, Converter={StaticResource BoolToVisibility}}">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- User ID -->
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,2"
                               Text="{Binding UserStatusText}"
                               Visibility="{Binding AccountId, Converter={StaticResource StringToVisibility}}"/>
                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="12,2" VerticalAlignment="Stretch"
                               Visibility="{Binding AccountId, Converter={StaticResource StringToVisibility}}"/>

                    <!-- Profile Resigner -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2">
                        <TextBlock Text="{x:Static props:Strings.ProfileLabel}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox ItemsSource="{Binding ProfileNames}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  FontSize="10" MinWidth="80" MaxWidth="160"
                                  VerticalAlignment="Center"
                                  ToolTip="{x:Static props:Strings.TooltipProfileSelector}"
                                  AutomationProperties.Name="{x:Static props:Strings.AutoProfileResigning}">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                    <Setter Property="IsEditable" Value="True"/>
                                    <Setter Property="IsReadOnly" Value="True"/>
                                    <Setter Property="Text" Value="None"/>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>
                        <Button Command="{Binding AddProfileCommand}"
                                Content="+" FontSize="12" FontWeight="Bold"
                                Width="24" Height="24" Padding="0"
                                VerticalAlignment="Center" Margin="2,0,0,0"
                                ToolTip="{x:Static props:Strings.TooltipAddProfile}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                AutomationProperties.Name="{x:Static props:Strings.AutoAddProfile}"/>
                        <Button Command="{Binding RemoveProfileCommand}"
                                Content="&#x2212;" FontSize="12" FontWeight="Bold"
                                Width="24" Height="24" Padding="0"
                                VerticalAlignment="Center"
                                ToolTip="{x:Static props:Strings.TooltipRemoveProfile}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                AutomationProperties.Name="{x:Static props:Strings.AutoRemoveProfile}"/>
                    </StackPanel>
                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="12,2" VerticalAlignment="Stretch"/>

                    <!-- Timezone selector -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2">
                        <ComboBox ItemsSource="{Binding AvailableTimeZones}"
                                  SelectedItem="{Binding SelectedTimeZone}"
                                  DisplayMemberPath="DisplayName"
                                  FontSize="10" MaxWidth="220" MinWidth="140"
                                  VerticalAlignment="Center"
                                  ToolTip="{x:Static props:Strings.TooltipTimezone}"
                                  AutomationProperties.Name="Display timezone"/>
                        <CheckBox IsChecked="{Binding UseDaylightSaving}"
                                  IsEnabled="{Binding CanApplyDst}"
                                  Content="{x:Static props:Strings.DST}" FontSize="10"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  VerticalAlignment="Center" Margin="6,0,0,0"
                                  ToolTip="{x:Static props:Strings.TooltipDst}"
                                  AutomationProperties.Name="Daylight saving time adjustment"/>
                    </StackPanel>
                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="12,2" VerticalAlignment="Stretch"/>

                    <!-- Trophy count -->
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,2"
                               Text="{Binding TrophiesStatusText}"/>
                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="12,2" VerticalAlignment="Stretch"/>

                    <!-- PSN EXP progress -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2">
                        <TextBlock Text="{x:Static props:Strings.EXP}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Grid VerticalAlignment="Center" Width="80" Height="8">
                            <Border Background="{StaticResource BorderBrush}" CornerRadius="4"/>
                            <Border CornerRadius="4" HorizontalAlignment="Left" ClipToBounds="True">
                                <Border.Background>
                                    <MultiBinding>
                                        <Binding Path="EarnedGrade"/>
                                        <Binding Path="TotalGrade"/>
                                        <Binding Path="HasPlatinum"/>
                                        <MultiBinding.Converter>
                                            <conv:FractionToColorConverter/>
                                        </MultiBinding.Converter>
                                    </MultiBinding>
                                </Border.Background>
                                <Border.Width>
                                    <MultiBinding>
                                        <Binding Path="EarnedGrade"/>
                                        <Binding Path="TotalGrade"/>
                                        <MultiBinding.Converter>
                                            <conv:FractionToWidthConverter MaxWidth="80"/>
                                        </MultiBinding.Converter>
                                    </MultiBinding>
                                </Border.Width>
                                <!-- Shimmer overlay for 100% completion -->
                                <Border CornerRadius="4" Width="80" IsHitTestVisible="False">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <!-- Respect reduced-motion accessibility setting -->
                                                <DataTrigger Binding="{Binding Source={x:Static SystemParameters.ClientAreaAnimation}}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding>
                                                            <Binding Path="EarnedGrade"/>
                                                            <Binding Path="TotalGrade"/>
                                                            <MultiBinding.Converter>
                                                                <conv:FractionIsCompleteConverter/>
                                                            </MultiBinding.Converter>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="ShimmerStoryboard">
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.Transform).(TranslateTransform.X)"
                                                                    From="-80" To="80" Duration="0:0:2"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <RemoveStoryboard BeginStoryboardName="ShimmerStoryboard"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <LinearGradientBrush.Transform>
                                                <TranslateTransform X="-80"/>
                                            </LinearGradientBrush.Transform>
                                            <GradientStop Color="Transparent" Offset="0.0"/>
                                            <GradientStop Color="#33FFFFFF" Offset="0.35"/>
                                            <GradientStop Color="#55FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="#33FFFFFF" Offset="0.65"/>
                                            <GradientStop Color="Transparent" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </Grid>
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="6,0,0,0">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} / {1}">
                                    <Binding Path="EarnedGrade"/>
                                    <Binding Path="TotalGrade"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </WrapPanel>
            </Border>

            <!-- Search + Filters (combined) -->
            <Border Grid.Row="1" Background="{StaticResource MenuBarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="16,5,16,5"
                    Visibility="{Binding IsFileOpen, Converter={StaticResource BoolToVisibility}}">
                <DockPanel>
                    <!-- Right: Clear filters + count -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding ClearAllFiltersCommand}"
                                Cursor="Hand"
                                Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVisibility}}"
                                AutomationProperties.Name="Clear all filters">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="Transparent"
                                            CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{x:Static props:Strings.ClearFilters}" FontSize="11"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="6,4"
                                   Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Text="{Binding FilteredStatusText}"/>
                    </StackPanel>

                    <!-- Left: Search + Filter chips -->
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center"
                               IsEnabled="{Binding IsFileOpen}">
                        <!-- Search cluster -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="SearchBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" Padding="6,4" MinWidth="120" MaxWidth="200"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     Background="White"
                                     AutomationProperties.Name="{x:Static props:Strings.AutoSearchTrophies}"
                                     ToolTip="{x:Static props:Strings.TooltipSearch}"/>
                            <Button Click="ClearSearch_Click"
                                    Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Visibility="{Binding SearchText, Converter={StaticResource StringToVisibility}}"
                                    AutomationProperties.Name="{x:Static props:Strings.AutoClearSearch}">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                            </Button>
                        </StackPanel>

                        <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="4,4"/>

                        <!-- Filter chips -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static props:Strings.FilterLabel}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ToggleButton Content="{x:Static props:Strings.FilterEarned}" IsChecked="{Binding FilterEarned}"
                                          Style="{StaticResource FilterChipToggle}"
                                          ToolTip="{x:Static props:Strings.TooltipFilterEarned}"
                                          AutomationProperties.Name="{x:Static props:Strings.TooltipFilterEarned}"/>
                            <ToggleButton Content="{x:Static props:Strings.FilterNotEarned}" IsChecked="{Binding FilterNotEarned}"
                                          Style="{StaticResource FilterChipToggle}"
                                          ToolTip="{x:Static props:Strings.TooltipFilterNotEarned}"
                                          AutomationProperties.Name="{x:Static props:Strings.TooltipFilterNotEarned}"/>
                            <ToggleButton Content="{x:Static props:Strings.FilterSynced}" IsChecked="{Binding FilterSynced}"
                                          Style="{StaticResource FilterChipToggle}"
                                          ToolTip="{x:Static props:Strings.TooltipFilterSynced}"
                                          AutomationProperties.Name="{x:Static props:Strings.TooltipFilterSynced}"/>
                            <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="6,4"/>
                            <ToggleButton Content="{x:Static props:Strings.FilterPlatinum}" IsChecked="{Binding FilterPlatinum}"
                                          Style="{StaticResource FilterChipToggle}"
                                          ToolTip="{x:Static props:Strings.TooltipFilterPlatinum}"
                                          AutomationProperties.Name="{x:Static props:Strings.TooltipFilterPlatinum}"/>
                            <ToggleButton Content="{x:Static props:Strings.FilterGold}" IsChecked="{Binding FilterGold}"
                                          Style="{StaticResource FilterChipToggle}"
                                          ToolTip="{x:Static props:Strings.TooltipFilterGold}"
                                          AutomationProperties.Name="{x:Static props:Strings.TooltipFilterGold}"/>
                            <ToggleButton Content="{x:Static props:Strings.FilterSilver}" IsChecked="{Binding FilterSilver}"
                                          Style="{StaticResource FilterChipToggle}"
                                          ToolTip="{x:Static props:Strings.TooltipFilterSilver}"
                                          AutomationProperties.Name="{x:Static props:Strings.TooltipFilterSilver}"/>
                            <ToggleButton Content="{x:Static props:Strings.FilterBronze}" IsChecked="{Binding FilterBronze}"
                                          Style="{StaticResource FilterChipToggle}"
                                          ToolTip="{x:Static props:Strings.TooltipFilterBronze}"
                                          AutomationProperties.Name="{x:Static props:Strings.TooltipFilterBronze}"/>
                        </StackPanel>
                    </WrapPanel>
                </DockPanel>
            </Border>

            <!-- Column Headers -->
            <Border Grid.Row="2" Background="{StaticResource MenuBarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="30,6,16,6"
                    Visibility="{Binding ShowColumnHeaders, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="74"/>
                        <ColumnDefinition Width="58"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{x:Static props:Strings.ColumnType}" FontSize="11.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ColumnIcon}" FontSize="11.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{x:Static props:Strings.ColumnTrophy}" FontSize="11.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </Grid>
            </Border>

            <!-- Empty State (no trophies loaded) -->
            <StackPanel Grid.Row="3"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibility}}"
                        AutomationProperties.LiveSetting="Polite"
                        AutomationProperties.Name="No trophies loaded.">
                <TextBlock Text="&#xE896;"
                           FontFamily="Segoe MDL2 Assets" FontSize="48"
                           Foreground="{StaticResource EmptyStateBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="{x:Static props:Strings.EmptyStateDrop}"
                           Style="{StaticResource EmptyStateText}"
                           Margin="0,0,0,6"/>
                <TextBlock Text="{x:Static props:Strings.EmptyStateBrowse}"
                           FontSize="13"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"/>

                <!-- Recent Files -->
                <StackPanel Margin="0,28,0,0"
                            Visibility="{Binding HasRecentFiles, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{x:Static props:Strings.Recent}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding RecentFiles}" HorizontalAlignment="Center">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button x:Name="RowBtn" Click="RecentItem_Click"
                                        Cursor="Hand" Margin="0,2">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="RowBg" Background="Transparent"
                                                    CornerRadius="6" Padding="10,6">
                                                <Grid MaxWidth="400">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding GameName}" FontSize="13"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Path}" FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                                                <TextBlock Text=" · " FontSize="11"
                                                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                                                                <TextBlock Text="{Binding RelativeTime}" FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button x:Name="RemoveBtn" Grid.Column="1"
                                                            Click="RemoveRecent_Click"
                                                            VerticalAlignment="Center" Margin="6,0,0,0"
                                                            Cursor="Hand" ToolTip="{x:Static props:Strings.TooltipRemoveRecent}"
                                                            Visibility="Hidden">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="XBg" Background="Transparent"
                                                                        CornerRadius="4" Padding="4,2">
                                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="XBg" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RowBg" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                                    <Setter TargetName="RemoveBtn" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <!-- Skeleton Loading Rows -->
            <Grid Grid.Row="3"
                  Visibility="{Binding IsLoadingTrophies, Converter={StaticResource BoolToVisibility}}"
                  ClipToBounds="True" Background="{StaticResource SurfaceBrush}">
                <!-- Mirrors ModernListViewItem exactly: FocusBorder(BorderThickness=2,CornerRadius=10,Margin=0,4) > ItemBorder(CornerRadius=8,Padding=12,10,BorderThickness=1) -->
                <!-- Text heights match Segoe UI line spacing: Name≈19px(FontSize14), Detail=18px(LineHeight=18), Status≈15px(FontSize11); gaps=3px matching real style margins -->
                <Border Background="{StaticResource SurfaceBrush}" Padding="16,12">
                    <StackPanel>
                        <!-- Card 1 -->
                        <Border BorderThickness="2" BorderBrush="Transparent" CornerRadius="10" Padding="0" Margin="0,4">
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10" Effect="{StaticResource CardShadow}">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="74"/><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BorderBrush}" CornerRadius="14" Width="44" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="{StaticResource BorderBrush}" CornerRadius="4" Width="48" Height="48" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="19" Width="220" HorizontalAlignment="Left"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="18" Width="155" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="15" Width="75" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>
                        <!-- Card 2 -->
                        <Border BorderThickness="2" BorderBrush="Transparent" CornerRadius="10" Padding="0" Margin="0,4">
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10" Effect="{StaticResource CardShadow}">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="74"/><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BorderBrush}" CornerRadius="14" Width="52" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="{StaticResource BorderBrush}" CornerRadius="4" Width="48" Height="48" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="19" Width="175" HorizontalAlignment="Left"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="18" Width="120" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="15" Width="62" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>
                        <!-- Card 3 -->
                        <Border BorderThickness="2" BorderBrush="Transparent" CornerRadius="10" Padding="0" Margin="0,4">
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10" Effect="{StaticResource CardShadow}">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="74"/><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BorderBrush}" CornerRadius="14" Width="44" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="{StaticResource BorderBrush}" CornerRadius="4" Width="48" Height="48" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="19" Width="258" HorizontalAlignment="Left"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="18" Width="185" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="15" Width="88" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>
                        <!-- Card 4 -->
                        <Border BorderThickness="2" BorderBrush="Transparent" CornerRadius="10" Padding="0" Margin="0,4">
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10" Effect="{StaticResource CardShadow}">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="74"/><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BorderBrush}" CornerRadius="14" Width="52" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="{StaticResource BorderBrush}" CornerRadius="4" Width="48" Height="48" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="19" Width="196" HorizontalAlignment="Left"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="18" Width="136" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="15" Width="70" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>
                        <!-- Card 5 -->
                        <Border BorderThickness="2" BorderBrush="Transparent" CornerRadius="10" Padding="0" Margin="0,4">
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10" Effect="{StaticResource CardShadow}">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="74"/><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BorderBrush}" CornerRadius="14" Width="44" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="{StaticResource BorderBrush}" CornerRadius="4" Width="48" Height="48" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="19" Width="238" HorizontalAlignment="Left"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="18" Width="170" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="15" Width="82" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>
                        <!-- Card 6 -->
                        <Border BorderThickness="2" BorderBrush="Transparent" CornerRadius="10" Padding="0" Margin="0,4">
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10" Effect="{StaticResource CardShadow}">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="74"/><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BorderBrush}" CornerRadius="14" Width="52" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="{StaticResource BorderBrush}" CornerRadius="4" Width="48" Height="48" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="19" Width="162" HorizontalAlignment="Left"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="18" Width="110" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="3" Height="15" Width="58" HorizontalAlignment="Left" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>
                    </StackPanel>
                </Border>
                <!-- Shimmer sweep overlay (respects reduced-motion accessibility setting) -->
                <Rectangle IsHitTestVisible="False"
                           Visibility="{Binding Source={x:Static SystemParameters.ClientAreaAnimation}, Converter={StaticResource BoolToVisibility}}">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <LinearGradientBrush.RelativeTransform>
                                <TranslateTransform x:Name="SkeletonShimmerTx" X="-1"/>
                            </LinearGradientBrush.RelativeTransform>
                            <GradientStop Color="Transparent" Offset="0.3"/>
                            <GradientStop Color="#50FFFFFF" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="0.7"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SkeletonShimmerTx"
                                                     Storyboard.TargetProperty="X"
                                                     From="-1" To="2" Duration="0:0:1.5"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
            </Grid>

            <!-- Trophy List -->
            <ListView x:Name="TrophyListView" Grid.Row="3" ItemsSource="{Binding Trophies}"
                      SelectionMode="Extended"
                      SelectionChanged="TrophyListView_SelectionChanged"
                      Visibility="{Binding ShowColumnHeaders, Converter={StaticResource BoolToVisibility}}"
                      Style="{StaticResource ModernListView}"
                      AutomationProperties.Name="Trophy list"
                      KeyboardNavigation.TabNavigation="Continue">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource ModernListViewItem}">
                        <Setter Property="local:DoubleClickBehavior.Command"
                                Value="{Binding DataContext.EditTimestampCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Setter Property="local:DoubleClickBehavior.CommandParameter"
                                Value="{Binding}"/>
                        <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
                        <Setter Property="ToolTipService.InitialShowDelay" Value="500"/>
                        <Setter Property="ToolTip">
                            <Setter.Value>
                                <ToolTip MaxWidth="350" Placement="Mouse">
                                    <ToolTip.Style>
                                        <Style TargetType="ToolTip">
                                            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                            <Setter Property="Padding" Value="14,10"/>
                                            <Setter Property="HasDropShadow" Value="True"/>
                                        </Style>
                                    </ToolTip.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Detail}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Border Background="{Binding TypeCode, Converter={StaticResource TypeToColor}}"
                                                    CornerRadius="8" Padding="8,2" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding TypeDisplayName}" FontSize="11"
                                                           Foreground="{Binding TypeCode, Converter={StaticResource TypeToColor}, ConverterParameter=Foreground}"/>
                                            </Border>
                                            <TextBlock Text="{Binding StatusDisplayName}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding FormattedEarnedDate}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </ToolTip>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu AutomationProperties.Name="Trophy actions">
                                    <!-- Batch actions (visible when multiple selected) -->
                                    <MenuItem Header="{Binding Data.SelectionStatusText, Source={StaticResource ViewModelProxy}}"
                                              IsEnabled="False" FontWeight="SemiBold">
                                        <MenuItem.Style>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasMultipleSelected, Source={StaticResource ViewModelProxy}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </MenuItem.Style>
                                    </MenuItem>
                                    <MenuItem Header="{x:Static props:Strings.UnlockSelected}" Command="{Binding Data.BatchUnlockCommand, Source={StaticResource ViewModelProxy}}">
                                        <MenuItem.Style>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasMultipleSelected, Source={StaticResource ViewModelProxy}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </MenuItem.Style>
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE785;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{x:Static props:Strings.LockSelected}" Command="{Binding Data.BatchLockCommand, Source={StaticResource ViewModelProxy}}">
                                        <MenuItem.Style>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasMultipleSelected, Source={StaticResource ViewModelProxy}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </MenuItem.Style>
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{x:Static props:Strings.ClearSelected}" Command="{Binding Data.BatchClearCommand, Source={StaticResource ViewModelProxy}}">
                                        <MenuItem.Style>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasMultipleSelected, Source={StaticResource ViewModelProxy}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </MenuItem.Style>
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource DestructiveBrush}"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator>
                                        <Separator.Style>
                                            <Style TargetType="Separator">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasMultipleSelected, Source={StaticResource ViewModelProxy}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Separator.Style>
                                    </Separator>
                                    <!-- Single-item actions -->
                                    <MenuItem Command="{Binding Data.ToggleTrophyCommand, Source={StaticResource ViewModelProxy}}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Style>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Header" Value="{x:Static props:Strings.Unlock}"/>
                                                <Setter Property="Icon">
                                                    <Setter.Value>
                                                        <TextBlock Text="&#xE785;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEarned}" Value="True">
                                                        <Setter Property="Header" Value="{x:Static props:Strings.Lock}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </MenuItem.Style>
                                    </MenuItem>
                                    <MenuItem Header="{x:Static props:Strings.EditTime}"
                                              Command="{Binding Data.EditTimestampCommand, Source={StaticResource ViewModelProxy}}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{x:Static props:Strings.Clear}"
                                              Command="{Binding Data.ClearTimestampCommand, Source={StaticResource ViewModelProxy}}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource DestructiveBrush}"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="{x:Static props:Strings.CopyName}"
                                              Command="{Binding Data.CopyTrophyNameCommand, Source={StaticResource ViewModelProxy}}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid AutomationProperties.Name="{Binding Name}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="74"/>
                                <ColumnDefinition Width="58"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Trophy Type Badge (pill) -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource TrophyBadge}"
                                    Margin="0,0,8,0"
                                    Background="{Binding TypeCode, Converter={StaticResource TypeToColor}}">
                                <TextBlock Text="{Binding TypeDisplayName}"
                                           Style="{StaticResource TrophyBadgeText}"
                                           Foreground="{Binding TypeCode, Converter={StaticResource TypeToColor}, ConverterParameter=Foreground}"
                                           AutomationProperties.Name="{Binding TypeDisplayName}"/>
                            </Border>

                            <!-- Trophy Icon (revealed) -->
                            <Border x:Name="IconBorder" Grid.Column="1" Style="{StaticResource TrophyIconBorder}">
                                <Image Source="{Binding IconPath}"
                                       Width="48" Height="48"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       AutomationProperties.Name="{Binding Name, StringFormat='{}{0} icon'}"/>
                            </Border>

                            <!-- Hidden Icon overlay (question mark, same size as real icon) -->
                            <Border x:Name="HiddenIconOverlay" Grid.Column="1" Style="{StaticResource TrophyIconBorder}"
                                    Visibility="Collapsed" Background="{StaticResource BorderBrush}">
                                <Grid Width="48" Height="48">
                                    <TextBlock Text="&#xE11B;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                            </Border>

                            <!-- Trophy Info (revealed) -->
                            <StackPanel x:Name="RevealedInfo" Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource TrophyNameText}"/>
                                    <TextBlock Text="·" FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="6,0,4,0"/>
                                    <TextBlock Text="{Binding GroupLabel}" FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Detail}" Style="{StaticResource TrophyDetailText}"/>
                                <!-- Set time link (for non-earned trophies) -->
                                <StackPanel x:Name="SetTimePanel" Orientation="Horizontal" Margin="0,3,0,0">
                                    <Button Command="{Binding DataContext.EditTimestampCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand" VerticalAlignment="Center"
                                            AutomationProperties.Name="Set unlock time">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                <TextBlock x:Name="SetTimeText" Text="{x:Static props:Strings.SetTime}"
                                                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                                            </StackPanel>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="SetTimeText" Property="TextDecorations" Value="Underline"/>
                                                                    <Setter TargetName="SetTimeText" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                                <!-- Status indicator (earned/synced) -->
                                <StackPanel x:Name="StatusPanel" Orientation="Horizontal" Margin="0,3,0,0"
                                            Visibility="Collapsed">
                                    <TextBlock x:Name="StatusIcon" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="StatusText" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button Command="{Binding DataContext.EditTimestampCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand" VerticalAlignment="Center"
                                            AutomationProperties.Name="Edit unlock time">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock x:Name="TimeText"
                                                                           Text="{Binding EarnedTime, Converter={StaticResource DateTimeFormat}}"
                                                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                <TextBlock x:Name="EditIcon" Text="&#xE70F;"
                                                                           FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           VerticalAlignment="Center" Margin="4,0,0,0"
                                                                           Visibility="Collapsed"/>
                                                            </StackPanel>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="TimeText" Property="TextDecorations" Value="Underline"/>
                                                                    <Setter TargetName="EditIcon" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <!-- Clear timestamp button -->
                                    <Button x:Name="ClearTimeButton"
                                            Command="{Binding DataContext.ClearTimestampCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand" VerticalAlignment="Center"
                                            AutomationProperties.Name="Clear unlock time">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text=" · " FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock x:Name="ClearText" Text="{x:Static props:Strings.Clear}"
                                                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                                            </StackPanel>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ClearText" Property="TextDecorations" Value="Underline"/>
                                                                    <Setter TargetName="ClearText" Property="Opacity" Value="1"/>
                                                                    <Setter TargetName="ClearText" Property="Foreground" Value="{StaticResource DestructiveBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- Trophy Info (hidden) -->
                            <StackPanel x:Name="HiddenInfo" Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{x:Static props:Strings.HiddenTrophy}" Style="{StaticResource TrophyNameText}"
                                               FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="·" FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="6,0,4,0"/>
                                    <TextBlock Text="{Binding GroupLabel}" FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{x:Static props:Strings.HiddenTrophyDesc}" Style="{StaticResource TrophyDetailText}"
                                           FontStyle="Italic"/>
                                <!-- Set time (non-earned) -->
                                <StackPanel x:Name="HiddenSetTimePanel" Orientation="Horizontal" Margin="0,3,0,0">
                                    <Button Command="{Binding DataContext.EditTimestampCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand" VerticalAlignment="Center"
                                            AutomationProperties.Name="Set unlock time">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                <TextBlock x:Name="SetTimeText" Text="{x:Static props:Strings.SetTime}"
                                                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                                            </StackPanel>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="SetTimeText" Property="TextDecorations" Value="Underline"/>
                                                                    <Setter TargetName="SetTimeText" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                                <!-- Status (earned/synced) -->
                                <StackPanel x:Name="HiddenStatusPanel" Orientation="Horizontal" Margin="0,3,0,0"
                                            Visibility="Collapsed">
                                    <TextBlock x:Name="HiddenStatusIcon" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="HiddenStatusText" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button Command="{Binding DataContext.EditTimestampCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand" VerticalAlignment="Center"
                                            AutomationProperties.Name="Edit unlock time">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock x:Name="TimeText"
                                                                           Text="{Binding EarnedTime, Converter={StaticResource DateTimeFormat}}"
                                                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                <TextBlock x:Name="EditIcon" Text="&#xE70F;"
                                                                           FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           VerticalAlignment="Center" Margin="4,0,0,0"
                                                                           Visibility="Collapsed"/>
                                                            </StackPanel>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="TimeText" Property="TextDecorations" Value="Underline"/>
                                                                    <Setter TargetName="EditIcon" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Command="{Binding DataContext.ClearTimestampCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand" VerticalAlignment="Center"
                                            AutomationProperties.Name="Clear unlock time">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text=" · " FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock x:Name="ClearText" Text="{x:Static props:Strings.Clear}"
                                                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                                            </StackPanel>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ClearText" Property="TextDecorations" Value="Underline"/>
                                                                    <Setter TargetName="ClearText" Property="Opacity" Value="1"/>
                                                                    <Setter TargetName="ClearText" Property="Foreground" Value="{StaticResource DestructiveBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <DataTemplate.Triggers>
                            <!-- Earned: hide set-time link, show status with timestamp -->
                            <DataTrigger Binding="{Binding IsEarned}" Value="True">
                                <Setter TargetName="SetTimePanel" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="StatusPanel" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="StatusIcon" Property="Text" Value="&#xE73E;"/>
                                <Setter TargetName="StatusIcon" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                <Setter TargetName="StatusText" Property="Text" Value="{x:Static props:Strings.FilterEarned}"/>
                                <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                <!-- Also update hidden state -->
                                <Setter TargetName="HiddenSetTimePanel" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="HiddenStatusPanel" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="HiddenStatusIcon" Property="Text" Value="&#xE73E;"/>
                                <Setter TargetName="HiddenStatusIcon" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                <Setter TargetName="HiddenStatusText" Property="Text" Value="{x:Static props:Strings.FilterEarned}"/>
                                <Setter TargetName="HiddenStatusText" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                            </DataTrigger>
                            <!-- Synced status indicator (orange lock, overrides earned) -->
                            <DataTrigger Binding="{Binding IsSynced}" Value="True">
                                <Setter TargetName="StatusPanel" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="StatusIcon" Property="Text" Value="&#xE72E;"/>
                                <Setter TargetName="StatusIcon" Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                <Setter TargetName="StatusText" Property="Text" Value="{x:Static props:Strings.FilterSynced}"/>
                                <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                <!-- Also update hidden state -->
                                <Setter TargetName="HiddenStatusPanel" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="HiddenStatusIcon" Property="Text" Value="&#xE72E;"/>
                                <Setter TargetName="HiddenStatusIcon" Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                <Setter TargetName="HiddenStatusText" Property="Text" Value="{x:Static props:Strings.FilterSynced}"/>
                                <Setter TargetName="HiddenStatusText" Property="Foreground" Value="{StaticResource WarningBrush}"/>
                            </DataTrigger>
                            <!-- When trophy is hidden and ShowHiddenTrophies is off, mask it -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsHidden}" Value="True"/>
                                    <Condition Binding="{Binding DataContext.ShowHiddenTrophies,
                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="IconBorder" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="HiddenIconOverlay" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="RevealedInfo" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="HiddenInfo" Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </DockPanel>
    <!-- Toast notification — slides up from bottom-right with smooth easing -->
    <Border x:Name="ToastBorder" HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,20,40"
            CornerRadius="12" Padding="16,12"
            Opacity="0" IsHitTestVisible="False"
            Visibility="Collapsed"
            AutomationProperties.Name="{Binding ToastMessage}"
            AutomationProperties.LiveSetting="Assertive">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="{StaticResource ToastBgStartColor}" Offset="0"/>
                <GradientStop Color="{StaticResource ToastBgEndColor}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.12" Color="Black"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="ToastTranslate" Y="30"/>
        </Border.RenderTransform>
        <StackPanel Orientation="Horizontal">
            <Border x:Name="ToastIconBg" CornerRadius="12" Width="24" Height="24"
                    VerticalAlignment="Center" Margin="0,0,10,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource ToastSuccessBgBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ToastType}" Value="{x:Static vm:ToastType.Error}">
                                <Setter Property="Background" Value="{StaticResource ToastErrorBgBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ToastType}" Value="{x:Static vm:ToastType.Info}">
                                <Setter Property="Background" Value="{StaticResource ToastInfoBgBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock x:Name="ToastIcon" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE73E;"/>
                            <Setter Property="Foreground" Value="{StaticResource ToastSuccessFgBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ToastType}" Value="{x:Static vm:ToastType.Error}">
                                    <Setter Property="Text" Value="&#xE711;"/>
                                    <Setter Property="Foreground" Value="{StaticResource ToastErrorFgBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ToastType}" Value="{x:Static vm:ToastType.Info}">
                                    <Setter Property="Text" Value="&#xE946;"/>
                                    <Setter Property="Foreground" Value="{StaticResource ToastInfoFgBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <TextBlock.RenderTransform>
                        <ScaleTransform x:Name="ToastIconScale" ScaleX="1" ScaleY="1"
                                        CenterX="6" CenterY="6"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Border>
            <TextBlock Text="{Binding ToastMessage}" FontSize="13" FontWeight="Medium"
                       Foreground="{StaticResource ToastTextBrush}" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>

    <!-- Busy Overlay -->
    <Border Background="{StaticResource OverlayBackdropBrush}"
            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
            IsHitTestVisible="{Binding IsBusy}"
            Focusable="True"
            KeyboardNavigation.TabNavigation="Cycle"
            AutomationProperties.Name="Please wait"
            AutomationProperties.LiveSetting="Assertive">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="&#xF16A;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                       Foreground="White" HorizontalAlignment="Center"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate"/>
                </TextBlock.RenderTransform>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                 Storyboard.TargetProperty="Angle"
                                                 From="0" To="360" Duration="0:0:1.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>
            <TextBlock Text="{Binding BusyMessage}" FontSize="14" Foreground="White"
                       FontWeight="Medium" HorizontalAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="300" Margin="0,16,0,0"/>
        </StackPanel>
    </Border>

    <!-- Keyboard Shortcuts Help Overlay -->
    <Border Background="{StaticResource OverlayBackdropBrush}"
            Visibility="{Binding ShowShortcutsHelp, Converter={StaticResource BoolToVisibility}}"
            IsHitTestVisible="{Binding ShowShortcutsHelp}"
            MouseDown="ShortcutsOverlay_MouseDown"
            AutomationProperties.Name="Keyboard shortcuts reference">
        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="28,24"
                MaxWidth="440" MinWidth="340" MaxHeight="480"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Effect="{StaticResource ElevationHigh}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{x:Static props:Strings.KeyboardShortcuts}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,16"/>
                <TextBlock DockPanel.Dock="Bottom" Text="{x:Static props:Strings.ShortcutsCloseHint}"
                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{x:Static props:Strings.ShortcutCatFile}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl+O" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutOpenFolder}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl+S" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutSave}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl+W" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutCloseFile}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,8"/>

                        <TextBlock Text="{x:Static props:Strings.ShortcutCatNavigation}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl+F" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutSearch}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Escape" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutEscape}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl+A" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutSelectAll}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,8"/>

                        <TextBlock Text="{x:Static props:Strings.ShortcutCatTrophyActions}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Space" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutToggle}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Enter" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutEditTime}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Delete" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutClearSelected}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,8"/>

                        <TextBlock Text="{x:Static props:Strings.ShortcutCatHelp}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="F1" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Static props:Strings.ShortcutHelp}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Grid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Border>

    <controls:ConfirmationDialogOverlay x:Name="ConfirmDialog"/>
    </Grid>
</Window>
