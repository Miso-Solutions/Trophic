<UserControl x:Class="Trophic.Controls.ConfirmationDialogOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:props="clr-namespace:Trophic.Properties"
             Visibility="Collapsed"
             AutomationProperties.Name="Confirmation dialog">
    <Grid x:Name="OverlayRoot" Background="{StaticResource OverlayBackdropBrush}"
          KeyboardNavigation.TabNavigation="Cycle"
          FocusManager.IsFocusScope="True"
          Focusable="True"
          KeyDown="OverlayRoot_KeyDown">
        <!-- Centered card -->
        <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="24"
                MaxWidth="420" MinWidth="300" MaxHeight="400"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Effect="{StaticResource ElevationHigh}">
            <DockPanel>
                <!-- Title (top) -->
                <TextBlock x:Name="TitleText" DockPanel.Dock="Top"
                           FontSize="15" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <!-- Buttons (bottom, always visible) -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="CopyButton" Click="CopyButton_Click"
                            Margin="0,0,8,0" Visibility="Collapsed"
                            Style="{StaticResource DialogSecondaryButton}"
                            AutomationProperties.Name="Copy">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="CopyIcon" Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="CopyLabel" Text="{x:Static props:Strings.Copy}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button x:Name="NoButton" Content="{x:Static props:Strings.No}" Click="NoButton_Click"
                            Margin="0,0,8,0"
                            Style="{StaticResource DialogSecondaryButton}"
                            AutomationProperties.Name="No"/>
                    <Button x:Name="YesButton" Content="{x:Static props:Strings.Yes}" Click="YesButton_Click"
                            Style="{StaticResource DialogPrimaryButton}"
                            AutomationProperties.Name="Yes"/>
                </StackPanel>
                <!-- Message (fills remaining space, scrollable) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,0"
                              Padding="0,0,4,0">
                    <StackPanel>
                        <TextBlock x:Name="MessageText" FontSize="13" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20"/>
                        <TextBox x:Name="InputBox" FontSize="13" Margin="0,10,0,0"
                                 Padding="8,6" Visibility="Collapsed"
                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 AutomationProperties.Name="Input field"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
