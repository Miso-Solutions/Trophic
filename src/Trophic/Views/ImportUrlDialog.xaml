<Window x:Class="Trophic.Views.ImportUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:props="clr-namespace:Trophic.Properties"
        Title="{x:Static props:Strings.ImportTimestampsTitle}"
        Height="410" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        AutomationProperties.Name="Import Timestamps">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" CornerRadius="8" GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Custom title bar -->
        <Grid Grid.Row="0" Background="{StaticResource MenuBarBrush}">
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/Resources/app.ico" Width="16" Height="16" Margin="0,0,8,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="{x:Static props:Strings.ImportTimestampsTitle}" FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Style="{StaticResource DialogCloseButton}" HorizontalAlignment="Right" Margin="0,3,4,3"
                    Click="CancelButton_Click" AutomationProperties.Name="Close">
                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
            </Button>
        </Grid>
    <Grid Grid.Row="1" Margin="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- URL input -->
        <TextBlock Grid.Row="0" Text="{x:Static props:Strings.TrophyPageUrl}" Margin="0,0,0,4" FontWeight="SemiBold"/>

        <TextBox x:Name="UrlBox" Grid.Row="1"
                 Margin="0,0,0,2" Padding="6,4"
                 FontSize="12"
                 KeyDown="UrlBox_KeyDown"
                 TextChanged="UrlBox_TextChanged"
                 AutomationProperties.Name="Trophy page URL"/>

        <TextBlock x:Name="UrlError" Grid.Row="2"
                   FontSize="11" Foreground="{StaticResource DestructiveBrush}"
                   Visibility="Collapsed" Margin="0,0,0,4"
                   Text="{x:Static props:Strings.InvalidUrlError}"/>

        <TextBlock Grid.Row="2"
                   FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                   TextWrapping="Wrap" Margin="0,16,0,10">
            <Run Text="{x:Static props:Strings.SupportedSites}"/>
        </TextBlock>

        <!-- Import mode selection -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <RadioButton x:Name="ModeAsIs" Grid.Column="0" Content="{x:Static props:Strings.ImportAsIs}"
                         IsChecked="True" Checked="Mode_Changed" Margin="0,0,0,10"
                         GroupName="ImportMode"
                         AutomationProperties.Name="Import timestamps as-is"/>
            <RadioButton x:Name="ModeOffset" Grid.Column="1" Content="{x:Static props:Strings.WithOffset}"
                         Checked="Mode_Changed" Margin="0,0,0,10"
                         GroupName="ImportMode"
                         AutomationProperties.Name="Import with time offset"/>
            <RadioButton x:Name="ModeFixed" Grid.Column="2" Content="{x:Static props:Strings.FixedValues}"
                         Checked="Mode_Changed" Margin="0,0,0,10"
                         GroupName="ImportMode"
                         AutomationProperties.Name="Import with fixed date values"/>
            <RadioButton x:Name="ModeStartTime" Grid.Column="3" Content="{x:Static props:Strings.StartTime}"
                         Checked="Mode_Changed" Margin="0,0,0,10"
                         GroupName="ImportMode"
                         AutomationProperties.Name="Import relative to start time"/>
        </Grid>

        <!-- Mode panels -->
        <Grid Grid.Row="4">
            <!-- As-is panel (empty, just info text) -->
            <TextBlock x:Name="PanelAsIs" Visibility="Visible"
                       FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Top"
                       TextWrapping="Wrap"
                       Text="{x:Static props:Strings.ImportAsIsDesc}"/>

            <!-- Offset panel -->
            <StackPanel x:Name="PanelOffset" Visibility="Collapsed">
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                           Text="{x:Static props:Strings.OffsetDesc}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Row 1: Years, Months, Weeks, Days -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static props:Strings.Years}" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="OffYears" Grid.Row="0" Grid.Column="1" Text="0" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                             AutomationProperties.Name="Offset years"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{x:Static props:Strings.Months}" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="OffMonths" Grid.Row="0" Grid.Column="4" Text="0" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                             AutomationProperties.Name="Offset months"/>
                    <TextBlock Grid.Row="0" Grid.Column="6" Text="{x:Static props:Strings.Weeks}" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="OffWeeks" Grid.Row="0" Grid.Column="7" Text="0" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                             AutomationProperties.Name="Offset weeks"/>
                    <TextBlock Grid.Row="0" Grid.Column="9" Text="{x:Static props:Strings.Days}" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="OffDays" Grid.Row="0" Grid.Column="10" Text="0" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                             AutomationProperties.Name="Offset days"/>
                    <!-- Row 2: Hours, Minutes, Seconds -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static props:Strings.Hours}" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="OffHours" Grid.Row="2" Grid.Column="1" Text="0" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                             AutomationProperties.Name="Offset hours"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{x:Static props:Strings.Minutes}" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="OffMinutes" Grid.Row="2" Grid.Column="4" Text="0" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                             AutomationProperties.Name="Offset minutes"/>
                    <TextBlock Grid.Row="2" Grid.Column="6" Text="{x:Static props:Strings.Seconds}" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="OffSeconds" Grid.Row="2" Grid.Column="7" Text="0" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                             AutomationProperties.Name="Offset seconds"/>
                </Grid>
                <TextBlock FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,8,0,0"
                           Text="{x:Static props:Strings.OffsetHint}"/>
            </StackPanel>

            <!-- Fixed values panel -->
            <StackPanel x:Name="PanelFixed" Visibility="Collapsed">
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                           Text="{x:Static props:Strings.FixedValuesDesc}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Row 1: Year, Month, Day -->
                    <CheckBox x:Name="ChkYear" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="FixedCheck_Changed" Unchecked="FixedCheck_Changed"
                              AutomationProperties.Name="Override year"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Static props:Strings.Year}" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                    <TextBox x:Name="FixYear" Grid.Row="0" Grid.Column="2" Text="2025" Padding="4,3" FontSize="12"
                             HorizontalContentAlignment="Center" IsEnabled="False"
                             AutomationProperties.Name="Fixed year value"/>

                    <CheckBox x:Name="ChkMonth" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="FixedCheck_Changed" Unchecked="FixedCheck_Changed"
                              AutomationProperties.Name="Override month"/>
                    <TextBlock Grid.Row="0" Grid.Column="5" Text="{x:Static props:Strings.Month}" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                    <TextBox x:Name="FixMonth" Grid.Row="0" Grid.Column="6" Text="1" Padding="4,3" FontSize="12"
                             HorizontalContentAlignment="Center" IsEnabled="False"
                             AutomationProperties.Name="Fixed month value"/>

                    <CheckBox x:Name="ChkDay" Grid.Row="0" Grid.Column="8" VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="FixedCheck_Changed" Unchecked="FixedCheck_Changed"
                              AutomationProperties.Name="Override day"/>
                    <TextBlock Grid.Row="0" Grid.Column="9" Text="{x:Static props:Strings.Day}" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                    <TextBox x:Name="FixDay" Grid.Row="0" Grid.Column="10" Text="1" Padding="4,3" FontSize="12"
                             HorizontalContentAlignment="Center" IsEnabled="False"
                             AutomationProperties.Name="Fixed day value"/>

                    <!-- Row 2: Hour, Minute, Second -->
                    <CheckBox x:Name="ChkHour" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="FixedCheck_Changed" Unchecked="FixedCheck_Changed"
                              AutomationProperties.Name="Override hour"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Static props:Strings.Hour}" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                    <TextBox x:Name="FixHour" Grid.Row="2" Grid.Column="2" Text="0" Padding="4,3" FontSize="12"
                             HorizontalContentAlignment="Center" IsEnabled="False"
                             AutomationProperties.Name="Fixed hour value"/>

                    <CheckBox x:Name="ChkMinute" Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="FixedCheck_Changed" Unchecked="FixedCheck_Changed"
                              AutomationProperties.Name="Override minute"/>
                    <TextBlock Grid.Row="2" Grid.Column="5" Text="{x:Static props:Strings.Minute}" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                    <TextBox x:Name="FixMinute" Grid.Row="2" Grid.Column="6" Text="0" Padding="4,3" FontSize="12"
                             HorizontalContentAlignment="Center" IsEnabled="False"
                             AutomationProperties.Name="Fixed minute value"/>

                    <CheckBox x:Name="ChkSecond" Grid.Row="2" Grid.Column="8" VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="FixedCheck_Changed" Unchecked="FixedCheck_Changed"
                              AutomationProperties.Name="Override second"/>
                    <TextBlock Grid.Row="2" Grid.Column="9" Text="{x:Static props:Strings.Second}" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                    <TextBox x:Name="FixSecond" Grid.Row="2" Grid.Column="10" Text="0" Padding="4,3" FontSize="12"
                             HorizontalContentAlignment="Center" IsEnabled="False"
                             AutomationProperties.Name="Fixed second value"/>
                </Grid>
                <TextBlock FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,8,0,0"
                           Text="{x:Static props:Strings.FixedValuesHint}"/>
            </StackPanel>

            <!-- Start time panel -->
            <StackPanel x:Name="PanelStartTime" Visibility="Collapsed">
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                           Text="{x:Static props:Strings.StartTimeDesc}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="{x:Static props:Strings.DateLabel}" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                        <DatePicker x:Name="StartDate" FontSize="12" Width="140"
                                    AutomationProperties.Name="Start date"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="{x:Static props:Strings.HourLabel}" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                        <TextBox x:Name="StartHour" Text="12" Width="40" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                                 AutomationProperties.Name="Start hour"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Text="{x:Static props:Strings.MinLabel}" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                        <TextBox x:Name="StartMinute" Text="0" Width="40" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                                 AutomationProperties.Name="Start minute"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="6" Orientation="Horizontal">
                        <TextBlock Text="{x:Static props:Strings.SecLabel}" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                        <TextBox x:Name="StartSecond" Text="0" Width="40" Padding="4,3" FontSize="12" HorizontalContentAlignment="Center"
                                 AutomationProperties.Name="Start second"/>
                    </StackPanel>
                </Grid>
                <TextBlock FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Text="{x:Static props:Strings.StartTimeExample}"/>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static props:Strings.Import}" Width="80" Margin="0,0,10,0"
                    Click="ImportButton_Click" IsDefault="True"
                    Style="{StaticResource DialogPrimaryButton}"
                    AutomationProperties.Name="Import timestamps"/>
            <Button Content="{x:Static props:Strings.Cancel}" Width="80"
                    Click="CancelButton_Click" IsCancel="True"
                    Style="{StaticResource DialogSecondaryButton}"
                    AutomationProperties.Name="Cancel import"/>
        </StackPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
