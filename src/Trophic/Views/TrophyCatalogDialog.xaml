<Window x:Class="Trophic.Views.TrophyCatalogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:props="clr-namespace:Trophic.Properties"
        Title="{x:Static props:Strings.CatalogTitle}"
        Height="560" Width="640"
        MinHeight="400" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        AutomationProperties.Name="Trophy Catalog">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" CornerRadius="8" GlassFrameThickness="0"
                      ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource MenuBarBrush}">
                <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/app.ico" Width="16" Height="16" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="TitleText" Text="{x:Static props:Strings.CatalogTitle}" FontSize="12"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Style="{StaticResource DialogCloseButton}" HorizontalAlignment="Right" Margin="0,3,4,3"
                        Click="CancelButton_Click" AutomationProperties.Name="Close">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                </Button>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16,12,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search box -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <TextBox x:Name="SearchBox" FontSize="13" Padding="30,7,8,7"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Background="{StaticResource InputBackgroundBrush}"
                             TextChanged="SearchBox_TextChanged"
                             AutomationProperties.Name="{x:Static props:Strings.CatalogSearchPlaceholder}"
                             WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <!-- Search icon -->
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               IsHitTestVisible="False"/>
                    <!-- Placeholder -->
                    <TextBlock x:Name="SearchPlaceholder" Text="{x:Static props:Strings.CatalogSearchPlaceholder}"
                               FontSize="13" Foreground="{StaticResource TextDisabledBrush}"
                               VerticalAlignment="Center" Margin="32,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Results count -->
                <TextBlock x:Name="ResultCountText" Grid.Row="1" FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>

                <!-- Results list -->
                <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="6"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                    <ListView x:Name="ResultsListView" Background="Transparent" BorderThickness="0"
                              Padding="4" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              MouseDoubleClick="ResultsListView_MouseDoubleClick"
                              SelectionChanged="ResultsListView_SelectionChanged"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              AutomationProperties.Name="Search results">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bg" Background="Transparent" CornerRadius="4" Padding="10,6">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentLightBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- NPWR ID -->
                                    <TextBlock Text="{Binding Id}" FontSize="11" FontFamily="Consolas"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <!-- Game name -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding OriginalName}" FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding OriginalName, Converter={StaticResource StringToVisibility}}"/>
                                    </StackPanel>
                                    <!-- Region badge -->
                                    <Border Grid.Column="2" CornerRadius="3" Padding="6,2" Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource BorderSubtleBrush}">
                                        <TextBlock Text="{Binding Region}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- Progress bar (hidden by default) -->
                <StackPanel x:Name="ProgressPanel" Grid.Row="3" Margin="0,8,0,0" Visibility="Collapsed">
                    <ProgressBar x:Name="DownloadProgress" Height="4" Minimum="0" Maximum="100"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource BorderSubtleBrush}"/>
                    <TextBlock x:Name="ProgressText" FontSize="11" Margin="0,4,0,0"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button x:Name="DownloadButton" Content="{x:Static props:Strings.CatalogDownloadOpen}"
                            MinWidth="120" Padding="16,0" Margin="0,0,10,0"
                            Click="DownloadButton_Click" IsDefault="True" IsEnabled="False"
                            Style="{StaticResource DialogPrimaryButton}"
                            AutomationProperties.Name="Download and open"/>
                    <Button Content="{x:Static props:Strings.Cancel}" Width="80"
                            Click="CancelButton_Click" IsCancel="True"
                            Style="{StaticResource DialogSecondaryButton}"
                            AutomationProperties.Name="Cancel"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
