<Window x:Class="Trophic.Views.DateTimePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:Trophic.Views"
        xmlns:props="clr-namespace:Trophic.Properties"
        Title="{x:Static props:Strings.SelectDateTimeTitle}"
        Height="236" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        AutomationProperties.Name="Select Date and Time">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" CornerRadius="8" GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Custom title bar -->
        <Grid Grid.Row="0" Background="{StaticResource MenuBarBrush}">
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/Resources/app.ico" Width="16" Height="16" Margin="0,0,8,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="{x:Static props:Strings.SelectDateTimeTitle}" FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Style="{StaticResource DialogCloseButton}" HorizontalAlignment="Right" Margin="0,3,4,3"
                    Click="CancelButton_Click" AutomationProperties.Name="Close">
                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
            </Button>
        </Grid>
    <Grid Grid.Row="1" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{x:Static props:Strings.SelectDateTimePrompt}" Grid.Row="0" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <DatePicker x:Name="DatePickerControl" Grid.Column="0"
                        AutomationProperties.Name="Trophy unlock date">
                <DatePicker.CalendarStyle>
                    <Style TargetType="Calendar">
                        <Setter Property="CalendarDayButtonStyle">
                            <Setter.Value>
                                <Style TargetType="CalendarDayButton" BasedOn="{StaticResource {x:Type CalendarDayButton}}">
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{x:Static local:FutureDateConverter.Instance}">
                                                    <Binding RelativeSource="{RelativeSource Self}" Path="DataContext"/>
                                                    <Binding Source="{x:Static sys:DateTime.Today}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Opacity" Value="0.35"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DatePicker.CalendarStyle>
            </DatePicker>
            <Button Grid.Column="1" Content="{x:Static props:Strings.Now}" Margin="8,0,0,0" Padding="8,2"
                    VerticalAlignment="Center" Click="TodayButton_Click"
                    AutomationProperties.Name="Set to current date and time"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Static props:Strings.HourLabel}" VerticalAlignment="Center" Grid.Column="0" Margin="0,0,5,0"/>
            <TextBox x:Name="HourBox" Grid.Column="1" Text="12"
                     AutomationProperties.Name="Hour (0-23)"/>
            <TextBlock Text="{x:Static props:Strings.MinLabel}" VerticalAlignment="Center" Grid.Column="2" Margin="10,0,5,0"/>
            <TextBox x:Name="MinuteBox" Grid.Column="3" Text="0"
                     AutomationProperties.Name="Minute (0-59)"/>
            <TextBlock Text="{x:Static props:Strings.SecLabel}" VerticalAlignment="Center" Grid.Column="4" Margin="10,0,5,0"/>
            <TextBox x:Name="SecondBox" Grid.Column="5" Text="0"
                     AutomationProperties.Name="Second (0-59)"/>
        </Grid>

        <TextBlock x:Name="FutureWarning" Grid.Row="3"
                   FontSize="11" Foreground="{StaticResource WarningBrush}"
                   TextWrapping="Wrap" Margin="0,6,0,0"
                   Visibility="Collapsed"
                   Text="{x:Static props:Strings.FutureDateWarning}"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static props:Strings.OK}" Width="75" Margin="0,0,10,0" Click="OkButton_Click" IsDefault="True"
                    Style="{StaticResource DialogPrimaryButton}"
                    AutomationProperties.Name="Confirm date and time"/>
            <Button Content="{x:Static props:Strings.Cancel}" Width="75" Click="CancelButton_Click" IsCancel="True"
                    Style="{StaticResource DialogSecondaryButton}"
                    AutomationProperties.Name="Cancel"/>
        </StackPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
